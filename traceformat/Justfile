default: ci

hook: lint test

fmt:
    uv run ruff format src tests

lint:
    uv run ruff format --check src tests
    uv run ruff check src tests

types:
    uv run pyrefly check

types-pyright:
    uv run pyright src tests

test:
    uv run pytest

cov:
    uv run pytest --cov=traceformat --cov-branch --cov-report=term-missing

lint-schema:
    uv run python -c 'import json; from jsonschema.validators import validator_for; s = json.load(open("trace-format.schema.json")); validator_for(s).check_schema(s); print("trace-format.schema.json: valid JSON Schema")'

gen-types:
    uv run datamodel-codegen \
        --input trace-format.schema.json \
        --input-file-type jsonschema \
        --output src/traceformat/models.py \
        --output-model-type pydantic_v2.BaseModel \
        --target-python-version 3.13 \
        --use-standard-collections \
        --field-constraints \
        --use-default-kwarg \
        --formatters ruff-format \
        --disable-timestamp

types-fresh:
    #!/usr/bin/env bash
    set -euo pipefail
    tmp="src/traceformat/_models_fresh.py"
    trap 'rm -f "$tmp"' EXIT
    uv run datamodel-codegen \
        --input trace-format.schema.json \
        --input-file-type jsonschema \
        --output "$tmp" \
        --output-model-type pydantic_v2.BaseModel \
        --target-python-version 3.13 \
        --use-standard-collections \
        --field-constraints \
        --use-default-kwarg \
        --formatters ruff-format \
        --disable-timestamp
    diff src/traceformat/models.py "$tmp"

ci: lint-schema types-fresh lint types test
