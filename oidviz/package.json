{
  "name": "oidviz",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "bun test --path-ignore-patterns \"tests/e2e/**\" --pass-with-no-tests",
    "lint": "bunx oxlint -D all -c .oxlintrc.json --ignore-pattern \"src/lib/types.gen.ts\" src/ && bunx biome check --formatter-enabled=false --error-on-warnings src/ && bunx eslint --max-warnings 0 src/"
  },
  "dependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.12.1",
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.47.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "json-schema-to-typescript": "^15.0.0",
    "oxlint": "^0.9.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vue-eslint-parser": "^9.0.0",
    "vue-tsc": "^2.1.0"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
