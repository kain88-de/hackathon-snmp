{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": { "all": true },
      "complexity": { "all": true },
      "correctness": {
        "all": true,
        "useImportExtensions": "off"
      },
      "performance": { "all": true },
      "security": { "all": true },
      "style": {
        "all": true,
        "useFilenamingConvention": "off"
      },
      "suspicious": { "all": true }
    }
  },
  "overrides": [
    {
      "include": ["*.vue", "src/vue-shim.d.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off",
            "useHookAtTopLevel": "off"
          },
          "style": { "noDefaultExport": "off" }
        }
      }
    },
    {
      "include": ["src/lib/types.gen.ts"],
      "linter": {
        "rules": {
          "style": { "useNamingConvention": "off" }
        }
      }
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  }
}
