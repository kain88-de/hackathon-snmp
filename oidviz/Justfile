set shell := ["bash", "-cu"]

dev:
    bun run dev

build:
    bun run build

fmt:
    bunx biome format --write src/

fmt-check:
    bunx biome check --linter-enabled=false src/

lint:
    bunx oxlint -D all -c .oxlintrc.json --ignore-pattern "src/lib/types.gen.ts" src/
    bunx biome check --formatter-enabled=false --error-on-warnings src/
    bunx eslint --max-warnings 0 src/

types:
    bunx vue-tsc --noEmit --skipLibCheck

test:
    bun test --path-ignore-patterns "tests/e2e/**" --pass-with-no-tests

ci: lint types fmt-check test e2e a11y

e2e:
    bunx playwright test

a11y:
    #!/usr/bin/env bash
    set -e
    bun run build
    bunx vite preview --port 4173 &
    SERVER_PID=$!
    trap "kill $SERVER_PID 2>/dev/null" EXIT
    sleep 2
    bunx axe http://localhost:4173 --exit

gen-types:
    bunx json-schema-to-typescript ../docs/trace-format.schema.json -o src/lib/types.gen.ts
