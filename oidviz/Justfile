# OIDviz development tasks

default:
    just --list

lint:
    bunx oxlint -D all -c .oxlintrc.json --ignore-pattern "src/lib/types.gen.ts" -A "unicorn/filename-case" -A "sort-imports" src/
    bunx biome check --formatter-enabled=false src/

types:
    bunx tsc --noEmit --skipLibCheck

fmt-check:
    bunx biome check --linter-enabled=false src/

fmt:
    bunx biome format --write src/

test:
    bun test

ci: lint types fmt-check test

a11y:
    #!/usr/bin/env bash
    set -e
    bun run build
    bunx vite preview --port 4173 &
    SERVER_PID=$!
    sleep 2
    bunx @axe-core/cli http://localhost:4173
    kill $SERVER_PID

dev:
    bun run dev

gen-types:
    bunx json-schema-to-typescript ../docs/trace-format.schema.json -o src/lib/types.gen.ts
    bunx biome format --write src/lib/types.gen.ts
