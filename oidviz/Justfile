dev:
    bun run dev

build:
    bun run build

preview:
    bun run preview

test:
    bun test

lint:
    bunx oxlint -D all -c .oxlintrc.json --ignore-pattern "src/lib/types.gen.ts" src/
    bunx biome check --formatter-enabled=false src/

types:
    bunx tsc --noEmit --skipLibCheck

fmt-check:
    bunx biome check --linter-enabled=false src/

fmt:
    bunx biome format --write src/

gen-types:
    bunx json-schema-to-typescript ../docs/trace-format.schema.json -o src/lib/types.gen.ts

a11y: build
    #!/usr/bin/env bash
    set -euo pipefail
    bunx vite preview --port 4173 &
    PREVIEW_PID=$!
    sleep 3
    bunx @axe-core/cli http://localhost:4173 || true
    kill $PREVIEW_PID 2>/dev/null || true

ci: lint types fmt-check test
