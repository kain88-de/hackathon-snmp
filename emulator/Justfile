# SNMP device emulator

# Run on the default SNMP port 161 (requires root)
run:
    sudo SNMP_PORT=161 .venv/bin/python snmp_emulator.py

# Run on unprivileged port 1161 (no sudo needed)
run-dev:
    uv run python snmp_emulator.py

# Quick smoke test against the dev port
test:
    snmpget -v2c -c public 127.0.0.1:1161 sysDescr.0
    snmpget -v2c -c public 127.0.0.1:1161 1.3.6.1.2.1.2.2.1.2.1

# Build and start two containers on 127.0.0.2 and 127.0.0.3 port 161
containers-start:
    ./start-containers.sh

# Stop and remove the containers
containers-stop:
    sudo podman rm -f snmp-device-1 snmp-device-2

# Follow logs from both containers
containers-logs:
    sudo podman logs -f snmp-device-1 &
    sudo podman logs -f snmp-device-2
